---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  category?: string;
  currentId?: string;
}

const { title, description = '', category = '', currentId = '' } = Astro.props;
const allDocs = await getCollection('docs');
const sameCategoryDocs = allDocs
  .filter(d => (d.data.category || 'uncategorized') === category && d.id !== currentId)
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const categoryMap: Record<string, string> = {
  rag: 'RAG 知识库',
  'ai-agent': 'AI Agent',
  uncategorized: '其他',
};
const categoryName = categoryMap[category] || category;
---

<BaseLayout title={`${title} · Learning Hub`} description={description}>
  <div style="display:flex;max-width:var(--max-width);margin:0 auto;padding:var(--space-group) 2rem;position:relative;">
    <!-- Sidebar: TOC -->
    <aside id="sidebar" style="width:var(--sidebar-width);flex-shrink:0;position:sticky;top:80px;align-self:flex-start;max-height:calc(100vh - 100px);overflow-y:auto;padding-right:var(--space-element);display:block;">
      <!-- Back link -->
      <a href="/" style="display:flex;align-items:center;gap:0.4rem;font-size:0.75rem;color:var(--text-dim);margin-bottom:1rem;transition:color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--text-dim)'">
        <i data-lucide="arrow-left" style="width:14px;height:14px;"></i>
        返回文档库
      </a>

      <!-- Category label -->
      <div style="font-size:0.68rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-dim);margin-bottom:0.5rem;font-weight:600;">{categoryName}</div>
      <div style="font-size:0.95rem;font-weight:600;color:var(--text-primary);margin-bottom:1.25rem;">{title}</div>

      <!-- TOC -->
      <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-dim);margin-bottom:0.75rem;font-weight:600;">本文目录</div>
      <nav id="toc-nav"></nav>

      <!-- Other docs in same category -->
      {sameCategoryDocs.length > 0 && (
        <div style="margin-top:1.5rem;padding-top:1rem;border-top:1px solid var(--border);">
          <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-dim);margin-bottom:0.5rem;font-weight:600;">其他文档</div>
          {sameCategoryDocs.map(doc => (
            <a href={`/docs/${doc.id}`} style="display:block;padding:0.35rem 0;font-size:0.78rem;color:var(--text-dim);line-height:1.4;transition:color 0.15s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--text-dim)'">{doc.data.title}</a>
          ))}
        </div>
      )}
    </aside>

    <!-- Content -->
    <article class="prose" id="doc-content" style="flex:1;min-width:0;padding-left:var(--space-element);">
      <slot />
    </article>
  </div>

  <!-- Mobile sidebar toggle -->
  <button id="sidebar-toggle" style="display:none;position:fixed;bottom:1.5rem;right:1.5rem;z-index:200;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-full);width:44px;height:44px;cursor:pointer;align-items:center;justify-content:center;" aria-label="目录">
    <i data-lucide="list" style="width:20px;height:20px;color:var(--text-secondary);"></i>
  </button>

  <style is:global>
    .toc-link {
      display: block;
      padding: 0.35rem 0;
      font-size: 0.82rem;
      color: var(--text-dim);
      line-height: 1.5;
      transition: color 0.15s;
      border-left: 2px solid transparent;
      padding-left: 0.75rem;
      margin-bottom: 0.1rem;
    }
    .toc-link:hover { color: var(--text-secondary); }
    .toc-link.toc-active {
      color: var(--text-primary);
      border-left-color: var(--text-primary);
    }
    .toc-link.toc-h3 {
      padding-left: 1.5rem;
      font-size: 0.78rem;
    }

    @media (max-width: 768px) {
      #sidebar {
        display: none;
        position: fixed;
        top: 60px;
        left: 0;
        width: 280px;
        height: calc(100vh - 60px);
        background: var(--bg-primary);
        border-right: 1px solid var(--border);
        z-index: 150;
        padding: 1.5rem;
        max-height: none;
      }
      #sidebar.open { display: block; }
      #sidebar-toggle { display: flex; }
    }
  </style>

  <script is:inline>
    // Build TOC from headings in the document content
    const content = document.getElementById('doc-content');
    const tocNav = document.getElementById('toc-nav');
    const headings = content?.querySelectorAll('h2, h3') || [];

    // Get the astro scope id from toc-nav to apply to dynamic elements
    const astroScope = tocNav?.getAttribute('data-astro-cid-');
    // Find the actual scoped attribute
    const tocNavAttrs = tocNav?.getAttributeNames() || [];
    const scopeAttr = tocNavAttrs.find(a => a.startsWith('data-astro-cid-')) || '';

    headings.forEach(h => {
      if (!h.id) {
        h.id = h.textContent?.trim().toLowerCase().replace(/[^\w\u4e00-\u9fff]+/g, '-').replace(/^-|-$/g, '') || '';
      }
      const link = document.createElement('a');
      link.className = 'toc-link' + (h.tagName === 'H3' ? ' toc-h3' : '');
      if (scopeAttr) link.setAttribute(scopeAttr, '');
      link.href = '#' + h.id;
      link.textContent = h.textContent;
      link.dataset.tocSlug = h.id;
      tocNav?.appendChild(link);
    });

    // Highlight current section on scroll
    const tocLinks = document.querySelectorAll('.toc-link');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('toc-active'));
          const active = document.querySelector('[data-toc-slug="' + entry.target.id + '"]');
          if (active) active.classList.add('toc-active');
        }
      });
    }, { rootMargin: '-80px 0px -70% 0px' });

    headings.forEach(h => { if (h.id) observer.observe(h); });

    // Mobile sidebar
    const sidebar = document.getElementById('sidebar');
    const toggle = document.getElementById('sidebar-toggle');
    toggle?.addEventListener('click', () => sidebar?.classList.toggle('open'));

    // Init lucide icons
    if (typeof lucide !== 'undefined') lucide.createIcons();
  </script>
</BaseLayout>
